# Required for /parse and /generate_plan
OPENAI_API_KEY=sk-...

# Optional. Default is gpt-4o-mini for parse/QC and gpt-4o for plan generation.
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_PLAN=gpt-4o

# Polite-pool contact for CrossRef User-Agent
CROSSREF_MAILTO=hackathon@example.com

# Material enrichment via Tavily (https://app.tavily.com — free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-...

# Optional tuning for supplier lookup
SUPPLIER_LOOKUP_TIMEOUT=8.0
SUPPLIER_LOOKUP_MAX_WORKERS=8
