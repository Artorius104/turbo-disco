# Required for /parse, /validate_hypothesis and /generate_plan
OPENAI_API_KEY=sk-...

# Optional. Default is gpt-4o-mini for parse/QC and gpt-4o for plan generation.
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_PLAN=gpt-4o

# Polite-pool contact (used by CrossRef and OpenAlex User-Agent)
CROSSREF_MAILTO=hackathon@example.com

# Optional fallback for material enrichment.
# The static catalog (backend/data/catalog.json) is the primary source of catalog
# numbers and prices. Tavily is only used for materials missing from the catalog.
# Free tier: 1000 searches/month. Get one at https://app.tavily.com.
# IMPORTANT: do NOT commit a real key here — put it in .env (which is gitignored).
TAVILY_API_KEY=

# Optional tuning for the Tavily fallback
SUPPLIER_LOOKUP_TIMEOUT=8.0
SUPPLIER_LOOKUP_MAX_WORKERS=8
